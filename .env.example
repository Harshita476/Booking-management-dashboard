# Postgres connection string from Neon (use the pooled connection string)
DATABASE_URL=

# Run `openssl rand -base64 32` to generate this
NEXTAUTH_SECRET=

# http://localhost:3000 in development, your real domain in production
NEXTAUTH_URL=http://localhost:3000

# Used once by the seed script to create the first admin account
ADMIN_EMAIL=admin@saltlinecharters.example
ADMIN_PASSWORD=change-this-before-seeding
