generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model BookingRequest {
  id            String   @id @default(cuid())
  name          String
  email         String
  preferredDate DateTime
  partySize     String
  details       String
  status        String   @default("new") // new | confirmed | declined
  createdAt     DateTime @default(now())

  @@index([createdAt])
  @@index([status])
}

model AdminUser {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String
}
